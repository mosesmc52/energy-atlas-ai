{$APP_DOMAIN} {
    @django path /about /about/* /pricing /pricing/* /checkout /checkout/* /alerts /alerts/* /billing /billing/* /stripe /stripe/* /secret-room /secret-room/* /admin /admin/* /static /static/* /auth /auth/ /auth/signin /auth/signin/* /auth/signup /auth/signup/* /auth/forgot /auth/forgot/* /auth/logout /auth/logout/* /auth/google /auth/google/* /auth/google/callback /auth/google/callback/*

    handle @django {
        reverse_proxy django:8000
    }

    handle {
        reverse_proxy chainlit:8001
    }
}
