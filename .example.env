OPENAI_API_KEY=your_openai_api_key
EIA_API_KEY=your_eia_api_key

SERVICE_ACCOUNT_FILE=./service-account.json
GOOGLE_SHEET_DOCUMENT_ID=your_google_sheet_document_id

DJANGO_SETTINGS_MODULE=main.settings
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC
DJANGO_STATIC_ROOT=app/staticfiles
DATABASE_URL=postgres://energy_atlas:energy_atlas@postgres:5432/energy_atlas
DATABASE_CONN_MAX_AGE=600
ATLAS_USE_LLM_NARRATION=true
APP_URL=https://your-domain.com

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false

FROM_ADDRESS=no-reply@your-domain.com
SERVER_EMAIL=no-reply@your-domain.com
EMAIL_SUBJECT_PREFIX=[Energy Atlas]
EMAIL_USE_SES=true
EMAIL_POSITIONS=false
TO_ADDRESSES=alerts@your-domain.com
AWS_SES_REGION_NAME=us-east-1
AWS_SES_REGION_ENDPOINT=email.us-east-1.amazonaws.com
AWS_SES_ACCESS_KEY_ID=your_aws_ses_access_key_id
AWS_SES_SECRET_ACCESS_KEY=your_aws_ses_secret_access_key
AWS_SES_SESSION_TOKEN=
AWS_SES_CONFIGURATION_SET=
AWS_SES_SOURCE_ARN=
AWS_SES_RETURN_PATH_ARN=
AWS_SES_FROM_ARN=

TF_VAR_name=energy-atlas-ai
TF_VAR_do_token=your_digitalocean_token
TF_VAR_ssh_key_fingerprint=your_ssh_key_fingerprint
TF_VAR_zilla_pubkey_path=/path/to/your/id_rsa.pub
TF_VAR_droplet_size=s-2vcpu-4gb
TF_VAR_region=sfo3

# Use `doctl vpcs list` to find this value.
TF_VAR_vpc_uuid=your_vpc_uuid

STRIPE_LIVE_MODE=false
STRIPE_TEST_SECRET_KEY=your_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
